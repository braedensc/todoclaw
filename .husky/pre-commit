#!/bin/sh
# Todoclaw pre-commit hook — layer 2 of 3 (bypassable via --no-verify; CI is the real gate)
#
# NOTE: git runs this via husky's runner under `sh -e` (any unguarded non-zero
# exit aborts the script), and it inherits the nvm *default* node — which may be
# older than secretlint needs. Both facts are handled below.

# ── Ensure a modern Node is on PATH (secretlint needs >= 20) ──────────────────
if ! node -e 'process.exit(+process.versions.node.split(".")[0] >= 20 ? 0 : 1)' 2>/dev/null; then
  for major in 24 22 20; do
    dir=$(ls -d "$HOME/.nvm/versions/node/v${major}".* 2>/dev/null | sort -V | tail -1)
    if [ -n "$dir" ]; then
      PATH="$dir/bin:$PATH"
      export PATH
      break
    fi
  done
fi

# ── 1. Block planning/ and real .env files from being staged ─────────────────
# Match planning/ or any path component starting with .env, then explicitly
# allow .env.example. (|| true so a no-match grep doesn't abort under `sh -e`)
FORBIDDEN=$(git diff --cached --name-only \
  | grep -E '^planning/|(^|/)\.env' \
  | grep -v -E '(^|/)\.env\.example$' \
  || true)
if [ -n "$FORBIDDEN" ]; then
  echo ""
  echo "  BLOCKED: Forbidden files in this commit:"
  echo "$FORBIDDEN" | sed 's/^/    /'
  echo ""
  echo "  planning/ is gitignored reference material and must never be published."
  echo "  .env files (other than .env.example) contain real secrets."
  echo ""
  exit 1
fi

# ── 2. Run secretlint on all staged files ────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED" ]; then
  if ! echo "$STAGED" | xargs node_modules/.bin/secretlint --secretlintrc .secretlintrc.json; then
    echo ""
    echo "  BLOCKED: secretlint found a potential secret in staged files."
    echo "  Remove the secret value and reference it by env var name only."
    echo ""
    exit 1
  fi
fi

exit 0
