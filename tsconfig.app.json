{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "noEmit": true,

    "skipLibCheck": true,

    /* Strictness — Stage 1 baseline (CLAUDE.md: TypeScript strict mode) */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true
  },
  "include": ["src"],
  // The service worker runs in the WebWorker lib, not DOM — its globals (self as
  // ServiceWorkerGlobalScope, PushEvent, …) conflict with this app config's DOM lib. It is compiled
  // by vite-plugin-pwa (esbuild) at build time, so exclude it from the app's tsc pass.
  "exclude": ["src/sw.ts"]
}
